{
    "name": "app/slim-mongo-api",
    "description": "Simple CRUD API with Slim 4 + MongoDB",
    "type": "project",
    "require": {
        "php": "^8.0",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.8",
        "mongodb/mongodb": "^1.15",
        "vlucas/phpdotenv": "^5.5",
        "firebase/php-jwt": "^6.11",
        "ramsey/uuid": "^4.7",
        "php-di/php-di": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "audit": {
            "ignore": {
                "PKSA-y2cr-5h3j-g3ys": "*"
            }
        }
    }
}
